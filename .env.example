NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel : appliquer les migrations SQL depuis la machine locale (Settings > Database > URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Ou jeton perso (Account > Access Tokens) pour npm run migrate:012 sans DATABASE_URL
# SUPABASE_ACCESS_TOKEN=sbp_...
